# Database
# Use this for local Docker PostgreSQL (Postgres container from docker-compose.yml)
DATABASE_URL="postgresql://postgres:password@localhost:5432/surf_school?schema=public"
# Alternatively, for development with SQLite:
# DATABASE_URL="file:./dev.db"

# Redis
REDIS_URL="redis://localhost:6379"

# Razorpay (Get these from Razorpay Dashboard)
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="..."

# WhatsApp Meta Cloud API (Get these from Meta Developers Dashboard)
WHATSAPP_WEBHOOK_VERIFY_TOKEN="your_verify_token"
WHATSAPP_ACCESS_TOKEN="your_access_token"
WHATSAPP_PHONE_NUMBER_ID="your_phone_id"

# Email (Resend)
RESEND_API_KEY="re_..."

# Admin Authentication
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin_secure_password"

# App Ports (Defaults for Turborepo)
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:4000"
